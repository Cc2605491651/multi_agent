# multi_agent 环境变量样例
# 本机用法：复制为 .env 然后 `set -a; source .env; set +a` 或直接 export

# === LLM provider 选择（ABC.A）===
# 支持：anthropic / openai / deepseek（默认）/ openrouter（备选）/ ollama
# 节点级 harness.provider 可覆盖此默认；planner 生成 DAG 时也会自行选 provider
LLM_PROVIDER=deepseek

# === API keys ===
# 主用：DeepSeek（便宜，长上下文好）
DEEPSEEK_API_KEY=

# 备选：OpenRouter（一个 key 通 100+ 模型，含 anthropic/openai 路由）
OPENROUTER_API_KEY=

# 其它（按需填）
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# 可选：覆盖默认 base_url（自部署 OpenAI 兼容服务）
# LLM_BASE_URL=https://my.self/v1

# === 沙箱后端选择 ===
# local：本机直接跑，无隔离，开发期默认（spec §7.1）
# e2b：云端 sandbox，按用量计费
SANDBOX_BACKEND=local

# === E2B 云沙箱（仅 SANDBOX_BACKEND=e2b 时需要）===
# 去 https://e2b.dev/dashboard 的 API Keys 页面拷一个 key 填到这里
# 注意：每次重新生成的 key 都要更新这里；不要把 key 提交到 git
E2B_API_KEY=

# 可选：使用自定义 e2b 模板 ID（留空走 e2b 官方默认模板）
E2B_TEMPLATE=

# 可选：sandbox 生存时长（秒），默认 3600 = 1 小时
E2B_SANDBOX_TIMEOUT=3600

# === Hugging Face（bge embedding 下载，国内代理常需）===
# 默认走代理，HF_TOKEN 留空也能用
HF_TOKEN=
